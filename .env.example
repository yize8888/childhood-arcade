# ---- Server ----
PORT=3000
NODE_ENV=development

# ---- First-boot admin ----
# Defaults to admin / admin123 — change it after first login via the profile
# menu, OR uncomment these to override BEFORE first boot.
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=please-change-me

# ---- Upload limits ----
MAX_UPLOAD_BYTES=104857600   # 100 MB

# ---- Data paths (default relative to project root) ----
DB_PATH=data/app.db
UPLOADS_DIR=data/uploads
BIOS_DIR=data/bios
SAVES_DIR=data/saves
CORES_DIR=data/cores

# ---- Vite dev-only ----
VITE_API_TARGET=http://localhost:3000
